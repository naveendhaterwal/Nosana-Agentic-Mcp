# Nosana Dashboard / Service API Key (if using managed services)
NOSANA_API_KEY=


# Path to your Solana wallet .json file (for on-chain SDK actions)
KEYPAIR_PATH=/path/to/id.json

# OR 
# You can provide your base58 phantom private key
# SOLANA_KEY=your_private_key_here

# Solana RPC Network (mainnet-beta or devnet)
SOLANA_NETWORK=mainnet-beta

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=nosana-agentic-mcp
